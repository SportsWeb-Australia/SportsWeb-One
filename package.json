{
  "name": "sportsweb-one-club-template",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "SportsWeb One — reusable football/netball club website template. Client zero: Dookie United FNC.",
  "scripts": {
    "dev": "vite",
    "gen:variant-sql": "node scripts/gen-variant-fence.mjs",
    "build": "node scripts/gen-variant-fence.mjs --check && node scripts/check-no-html-sink.mjs && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "guard:html": "node scripts/check-no-html-sink.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "happy-dom": "^20.10.6",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vitest": "^4.1.10"
  }
}
